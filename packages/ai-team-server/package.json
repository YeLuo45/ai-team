    "express": "^4.21.2",
    "jsonwebtoken": "9.0.3",
    "multer": "2.2.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "22.19.21",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "4.22.4",
    "typescript": "^5.6.3"
  },
  "files": [
    "dist"
  ]
