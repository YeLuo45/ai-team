{
  "name": "ai-team",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered team management: smart interviews, member development, skill tracking, growth trajectories. TypeScript monorepo inspired by pi-mono.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @ai-team/core && npm run build -w @ai-team/ai && npm run build -w @ai-team/agent && npm run build -w @ai-team/server && npm run build -w @ai-team/tui && npm run build -w @ai-team/cli && npm run build -w @ai-team/web",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test vitest run",
    "test:coverage": "NODE_ENV=test vitest run --coverage && node scripts/coverage-report.mjs",
    "test:coverage:strict": "NODE_ENV=test vitest run --coverage && node scripts/coverage-report.mjs --strict-min=95",
    "test:coverage:90": "NODE_ENV=test vitest run --coverage && node scripts/coverage-report.mjs --strict-min=90",
    "coverage:report": "node scripts/coverage-report.mjs",
    "dev:web": "npm run dev -w @ai-team/web",
    "dev:server": "npm run dev -w @ai-team/server",
    "dev:web:prod": "cd packages/ai-team-web && node ../../node_modules/vite/bin/vite.js --host 0.0.0.0 --port 5173",
    "dev:server:prod": "AI_TEAM_DATA_DIR=$(pwd)/data PORT=3000 node packages/ai-team-server/dist/index.js",
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server:prod\" \"npm:dev:web:prod\"",
    "dev:tsc": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:cli": "node packages/ai-team-cli/bin/ai-team",
    "dev:tui": "node packages/ai-team-cli/bin/ai-team tui",
    "build:web": "npm run build -w @ai-team/web",
    "build:cli": "npm run build -w @ai-team/cli",
    "build:tui": "npm run build -w @ai-team/tui",
    "build:server": "npm run build -w @ai-team/server",
    "lint": "echo 'lint placeholder'",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "keywords": [
    "ai",
    "team-management",
    "interview",
    "hiring",
    "llm"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^22.10.2",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "concurrently": "9.2.3",
    "happy-dom": "20.10.6",
    "supertest": "7.2.2",
    "typescript": "^5.6.3",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.9",
    "workbox-window": "7.4.1"
  },
  "dependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/jsonwebtoken": "9.0.10",
    "bcryptjs": "3.0.3",
    "jsonwebtoken": "9.0.3"
  }
}
